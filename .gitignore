# ============================================
# AlphaSpectrum - Git Ignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Production builds
dist/
dist-ssr/
build/
*.local

# Environment files (NEVER commit these!)
.env
.env.*.local
!.env.example
!.env.*.example

# Database
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Testing
coverage/
.nyc_output/

# Misc
.cache/
.temp/
*.tgz
*.tar.gz

# Prisma
prisma/migrations/*/migration_lock.toml

# Docker
.dockerignore
docker-compose.override.yml

# Kubernetes secrets
k8s/secrets.yaml
!k8s/secrets.yaml.example

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
