apiVersion: v1
kind: Secret
metadata:
  name: alphaspectrum-secrets
  namespace: alphaspectrum
type: Opaque
stringData:
  DATABASE_URL: "postgresql://user:password@postgres:5432/alphaspectrum"
  REDIS_URL: "redis://redis:6379"
  JWT_SECRET: "change-me-to-a-random-secret-at-least-32-characters-long"
  ENCRYPTION_KEY: "change-me-to-a-32-character-key"
  ALPHA_VANTAGE_API_KEY: ""
  TWELVE_DATA_API_KEY: ""
  SMTP_HOST: ""
  SMTP_USER: ""
  SMTP_PASS: ""
