# ============================================
# AlphaSpectrum Enterprise - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED VARIABLES
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/alphaspectrum"

# JWT Secret (generate a strong random string, min 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"

# Encryption Key (exactly 32 characters for AES-256)
ENCRYPTION_KEY="your-32-character-encryption-key!"

# ============================================
# RECOMMENDED VARIABLES
# ============================================

# Redis (for caching, rate limiting, sessions)
REDIS_URL="redis://localhost:6379"

# Client URL (for CORS and email links)
CLIENT_URL="http://localhost:5173"

# Server Port
PORT=3001

# External APIs (at least one is needed for stock data)
# Get free API keys from:
# - Alpha Vantage: https://www.alphavantage.co/support/#api-key
# - Twelve Data: https://twelvedata.com/pricing
# - Financial Modeling Prep: https://financialmodelingprep.com/developer/docs/pricing
ALPHA_VANTAGE_API_KEY=""
TWELVE_DATA_API_KEY=""
FMP_API_KEY=""

# ============================================
# OPTIONAL VARIABLES
# ============================================

# SMTP Configuration (for email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@alphaspectrum.app"
EMAIL_FROM_NAME="AlphaSpectrum"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Sentry (error tracking)
SENTRY_DSN=""

# ============================================
# ADVANCED CONFIGURATION (usually not needed)
# ============================================

# JWT Configuration
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_ISSUER="alphaspectrum"
JWT_AUDIENCE="alphaspectrum-api"

# Security Settings
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
PASSWORD_HISTORY_SIZE=5
MFA_ENABLED=true
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket Settings
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"

# Feature Flags
FEATURE_WEBHOOKS=true
FEATURE_API_KEYS=true
FEATURE_SSO=false
FEATURE_AUDIT_LOGS=true
FEATURE_BULK_OPERATIONS=true
