# Database
DATABASE_URL="postgresql://user:password@localhost:5432/stockwise_pro"

# JWT Secret (generate a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Twelve Data API Key (recommended - works on Render)
TWELVE_DATA_API_KEY="5d46d9eaab13410c9821b13caabab6c7"

# FMP API Key (optional - fallback)
FMP_API_KEY=""

# Client URL (for CORS and email links)
CLIENT_URL="http://localhost:5173"

# Server Port
PORT=3001

